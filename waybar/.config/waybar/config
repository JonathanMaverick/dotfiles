{
  "layer": "top",
  "position": "top",
  "margin": "0 0 0 0",
  "height": 44,

  "modules-left": ["custom/launcher", "clock", "hyprland/workspaces", "hyprland/window"],
  "modules-center": [],
  "modules-right": [
    "custom/song",
    "custom/notifications",
    "network",
    "bluetooth",
    "pulseaudio",
    "custom/bright",
    "custom/theme",
    "cpu",
    "memory",
    "battery",
    "custom/power",
    "tray"
  ],

  "custom/bright": {
    "format": "¾░âá {}",
    "exec": "~/.config/waybar/brightness.sh",
    "interval": 60,
    "signal": 8,
    "on-scroll-up": "~/.config/waybar/brightness.sh up",
    "on-scroll-down": "~/.config/waybar/brightness.sh down",
    "tooltip": false
  },

  "custom/song": {
    "format": "¾░Äê {}",
    "exec": "bash -c 'playerctl metadata --format \"{{ title }} - {{ artist }}\" 2>/dev/null || echo \"No music\"'",
    "max-length": 35,
    "interval": 2,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": false
  },

  "custom/launcher": {
    "format": "¾▒äà",
    "tooltip": false,
    "on-click": "wofi"
  },

  "custom/notifications": {
    "exec": "~/.config/waybar/notifications.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "makoctl dismiss --all",
    "on-click-right": "makoctl mode -t do-not-disturb"
  },

  "custom/power": {
    "format": "ÔÅ╗",
    "tooltip": false,
    "on-click": "~/.config/waybar/power-menu.sh"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "¾░▓á",
      "2": "¾░▓ó",
      "3": "¾░▓ñ",
      "4": "¾░▓ª",
      "5": "¾░▓¿",
      "6": "¾░▓¬",
      "7": "¾░▓¼",
      "8": "¾░▓«",
      "9": "¾░▓░",
      "active": "¾░«»",
      "default": "¾░èá"
    },
    "persistent-workspaces": {
      "eDP-1": [1, 2, 3, 4, 5],
      "DP-2": [6, 7, 8, 9, 10]
    }
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true,
    "rewrite": {
      "": "Desktop"
    }
  },

  "clock": {
    "interval": 1,
    "format": " {0:%H:%M:%S}   ¾░â¡ {0:%A, %d %B %Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾░éä {capacity}%",
    "format-plugged": "¾░ÜÑ {capacity}%",
    "format-full": "¾▒ƒó {capacity}%",
    "format-icons": ["¾▒âì", "¾░ü║", "¾░ü╝", "¾░ü¥", "¾░éÇ", "¾░ü╣"],
    "tooltip-format": "{timeTo}\n{power}W"
  },

  "cpu": {
    "interval": 5,
    "format": "¾░ìø {usage}%",
    "tooltip-format": "{avg_frequency}GHz",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "memory": {
    "interval": 10,
    "format": "¾░¥å {percentage}%",
    "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Øƒ {volume}%",
    "format-icons": {
      "headphone": "¾░ïï",
      "hands-free": "¾▒íÅ",
      "headset": "¾░ïÄ",
      "phone": "¾░ä£",
      "portable": "¾░ªº",
      "car": "¾░äï",
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "scroll-step": 5,
    "tooltip-format": "{desc}"
  },

  "network": {
    "interval": 5,
    "format-wifi": "¾░û¿ {essid}",
    "format-ethernet": "¾░êÇ Connected",
    "format-disconnected": "¾░û¬ Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n¾░×Æ {bandwidthDownBytes}  ¾░×ò {bandwidthUpBytes}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}\n¾░×Æ {bandwidthDownBytes}  ¾░×ò {bandwidthUpBytes}",
    "on-click": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "¾░é»",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒ {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager"
  },

  "custom/theme": {
    "exec": "~/.config/waybar/theme-toggle.sh",
    "interval": 5,
    "on-click": "~/.config/waybar/theme-toggle.sh toggle",
    "tooltip": false
  },

  "tray": {
    "icon-size": 18,
    "spacing": 10
  }
}
