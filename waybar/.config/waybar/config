{
  "layer": "top",
  "position": "top",
  "margin": "0 0 0 0",
  "height": 44,

  "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/song",
    "network",
    "bluetooth",
    "pulseaudio",
    "custom/bright",
    "battery",
    "custom/power",
    "tray"
  ],

  "custom/bright": {
    "format": "ٍ░âب {}",
    "exec": "~/.config/waybar/brightness.sh",
    "interval": 2,
    "on-scroll-up": "~/.config/waybar/brightness.sh up",
    "on-scroll-down": "~/.config/waybar/brightness.sh down",
    "tooltip": false
  },

  "custom/song": {
    "format": "ٍ░ê {}",
    "exec": "bash -c 'playerctl metadata --format \"{{ title }} - {{ artist }}\" 2>/dev/null | cut -c -30 || echo No music'",
    "interval": 2,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": false
  },

  "custom/launcher": {
    "format": "ٍ▒à",
    "tooltip": false,
    "on-click": "wofi"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "ٍ░▓ب",
      "2": "ٍ░▓ت",
      "3": "ٍ░▓ج",
      "4": "ٍ░▓خ",
      "5": "ٍ░▓ذ",
      "6": "ٍ░▓ز",
      "7": "ٍ░▓ش",
      "8": "ٍ░▓«",
      "9": "ٍ░▓░",
      "active": "ٍ░«»",
      "default": "ٍ░èب"
    },
    "persistent-workspaces": {
      "eDP-1": [1, 2, 3, 4, 5],
      "DP-2": [6, 7, 8, 9, 10]
    }
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true,
    "rewrite": {
      "": "Desktop"
    }
  },

  "clock": {
    "interval": 1,
    "format": " {0:%H:%M:%S}   ٍ░âص {0:%A, %d %B %Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "ٍ░é {capacity}%",
    "format-plugged": "ٍ░أح {capacity}%",
    "format-full": "ٍ▒ات {capacity}%",
    "format-icons": ["ٍ▒â", "ٍ░║", "ٍ░╝", "ٍ░╛", "ٍ░é", "ٍ░╣"],
    "tooltip-format": "{timeTo}\n{power}W"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "ٍ░إا {volume}%",
    "format-icons": {
      "headphone": "ٍ░ïï",
      "hands-free": "ٍ▒ة",
      "headset": "ٍ░ï",
      "phone": "ٍ░£",
      "portable": "ٍ░خد",
      "car": "ٍ░ï",
      "default": ["ٍ░ـ┐", "ٍ░û", "ٍ░ـ╛"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "scroll-step": 5,
    "tooltip-format": "{desc}"
  },

  "network": {
    "format-wifi": "ٍ░ûذ {essid}",
    "format-ethernet": "ٍ░ê Connected",
    "format-disconnected": "ٍ░ûز Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nٍ░ئْ {bandwidthDownBytes}  ٍ░ئـ {bandwidthUpBytes}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}\nٍ░ئْ {bandwidthDownBytes}  ٍ░ئـ {bandwidthUpBytes}",
    "on-click": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "ٍ░é»",
    "format-disabled": "ٍ░é▓",
    "format-connected": "ٍ░é▒ {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager"
  },

  "custom/power": {
    "format": "ظ╗",
    "tooltip": false,
    "on-click": "exit"
  },

  "tray": {
    "icon-size": 18,
    "spacing": 10
  }
}
